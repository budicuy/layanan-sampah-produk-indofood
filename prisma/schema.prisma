generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Tabel User — satu-satunya tabel entitas bisnis.
// Better Auth membutuhkan: id (String), name, email, emailVerified, image, createdAt, updatedAt.
// Field tambahan proyek: username (unik), role.

model User {
  id            String     @id @default(cuid())
  name          String
  email         String     @unique
  emailVerified Boolean    @default(false)
  username      String     @unique
  role          Role       @default(KONSUMEN)
  status        StatusUser @default(AKTIF)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  sessions   Session[]
  accounts   Account[]
  nasabah    Nasabah?
  ekpedisiId String[]
  ekpedisi   Ekpedisi?

  @@map("user")
}

// Tabel Session — dikelola Better Auth.
model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

// Tabel Account — dikelola Better Auth (menyimpan hash password).
model Account {
  id           String    @id
  accountId    String
  providerId   String
  userId       String
  accessToken  String?
  refreshToken String?
  idToken      String?
  expiresAt    DateTime?
  password     String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

// Tabel Verification — dikelola Better Auth (email verify, dll).
model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

enum Role {
  KONSUMEN
  ADMIN
  HRD
}

model Nasabah {
  id          String          @id @default(cuid())
  userId      String?         @unique // Relasi ke User
  user        User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  nama        String
  alamat      String
  noTelp      String
  kategori    KategoriNasabah
  nik         String          @unique // No Nasabah (NIK)
  noRek       String
  jenisBank   String
  fotoLokasi  String?
  titikLokasi String? // Koordinat
  status      StatusNasabah   @default(AKTIF)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("nasabah")
}

enum KategoriNasabah {
  BANK_SAMPAH
  WARMIENDO
  PERORANGAN
}

enum StatusNasabah {
  AKTIF
  NONAKTIF
}

model Produk {
  id        String      @id @default(cuid())
  kode      String      @unique
  nama      String
  jenis     JenisProduk
  berat     Float
  brand     String
  harga     Int
  isi       Int
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@map("produk")
}

enum JenisProduk {
  PLASTIK
  KARTON
}

enum StatusUser {
  AKTIF
  NONAKTIF
}

model Ekpedisi {
  id          String         @id @default(cuid())
  userId      String?        @unique // Relasi ke User
  noTelp      String
  alamat      String
  titikLokasi String?
  status      StatusEkpedisi @default(BELUM_DI_PROSES)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("ekpedisi")
}

enum StatusEkpedisi {
  BELUM_DI_PROSES
  PROSES
  DONE
}

model HargaSampah {
  id          String      @id @default(cuid())
  harga       Int
  bulan       DateTime
  jenisSampah JenisSampah
  berat       Float
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("harga_sampah")
}

enum JenisSampah {
  PLASTIK
  KARTON
}
